---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import Testimonials from "../components/Testimonials.astro";
import Faq from "../components/Faq.astro";
import CtaBand from "../components/CtaBand.astro";
import { SITE } from "../config/site";
---
<Base
  title={`${SITE.services[0].title.replace(/^\w/, c => c.toUpperCase())} ${SITE.address.town} | ${SITE.name}`}
  description={`${SITE.name} — ${SITE.tagline}. Servicing ${SITE.serviceArea.join(", ")}. Call ${SITE.phone}.`}
>
  <Hero />
  <ServicesGrid />
  <Testimonials />
  <Faq />
  <CtaBand />
</Base>
